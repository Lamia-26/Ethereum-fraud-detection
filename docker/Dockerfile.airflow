# Image Airflow avec les dependances des DAGs uniquement.
# On monte src/ via volume + PYTHONPATH pour eviter de reinstaller sqlalchemy.

FROM apache/airflow:2.10.4

USER root
RUN apt-get update && apt-get install -y --no-install-recommends libgomp1 && rm -rf /var/lib/apt/lists/*

USER airflow
RUN pip install --no-cache-dir \
    httpx \
    pandas \
    mlflow \
    scikit-learn \
    joblib \
    xgboost \
    lightgbm \
    matplotlib \
    optuna \
    shap \
    python-dotenv
